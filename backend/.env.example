# ============================================
# ImpactMatch Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
# Local:  mongodb://localhost:27017/impactmatch
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/impactmatch
MONGO_URI=mongodb://localhost:27017/impactmatch

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Client URL (for CORS and certificate links)
CLIENT_URL=http://localhost:3000

# Attendance check-in radius in meters (default: 200)
CHECK_IN_RADIUS_METERS=200

# File uploads directory (optional — defaults to /uploads)
UPLOADS_DIR=./uploads
